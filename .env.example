# Environment Variables Template
# Copy this file to .env and fill in your API keys.
# NEVER commit .env or paste real keys into chat or docs.
#
# Pipeline is kie.ai Kling 3.0 text-to-video only.
# Which key is which (by format):
#   - Starts with sk-proj- or sk-     → OPENAI_API_KEY (script generation)
#   - kie.ai key (https://kie.ai/api-key) → KIE_API_KEY (Kling 3.0 text-to-video)
#   - Cloud name + key + secret      → CLOUDINARY_* (optional, CDN uploads)

# === Required for pipeline (Kling 3.0 via kie.ai) ===
OPENAI_API_KEY=your_openai_api_key_here
KIE_API_KEY=your_kie_api_key_here

# === Optional: Google Gemini (alternative for script) ===
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# === Optional: Gemini QA trims ===
# GEMINI_QA_ENABLED=true
# GEMINI_MAX_VIDEO_MB=20

# === Optional: Audio polish ===
# AUDIO_POLISH_ENABLED=true
# MUSIC_BED_PATH=./static/music-bed.mp3
# MUSIC_BED_VOLUME=0.18
# MUSIC_BED_DUCKING=true

# === Optional: Cloudinary (CDN uploads; else videos stored in ./outputs) ===
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# === Application ===
DEBUG=True
PORT=8000
HOST=0.0.0.0

# === Optional: Kling 3.0 (Standard 720p with audio = 30 credits/s) ===
# KLING_QUALITY=720p        # 720p (Standard) or 1080p (Pro). Default 720p.
# KLING_SOUND_RETRY=false   # Default: no retry on audio error; failure is shown on UI. Set true to retry once without sound (2nd KIE task).

# === Pipeline modes ===
# USE_MULTI_PROMPT=true               # Use Kling multi_prompt (single clip) when last-frame continuity is off.
# USE_LAST_FRAME_CONTINUITY=true      # Sequential scene generation with last-frame chaining.
# SCENE_RETRY_LIMIT=1                 # Per-scene retries (KIE credits apply per retry).
# DEFAULT_SCENE_TRIM_START_SECONDS=1.0
# BASE_URL=http://localhost:8000      # Public base URL for last-frame images when Cloudinary not set.

# === Enterprise / scale ===
# REDIS_URL=redis://localhost:6379/0   # Required for multi-instance; job store
# RATE_LIMIT_PER_HOUR=50               # Max POST /generate per IP per hour (0=disabled)
# CORS_ORIGINS=*                       # Comma-separated; restrict in production
# LOG_LEVEL=INFO                       # DEBUG, INFO, WARNING, ERROR
# LOG_FORMAT=default                   # default | json (for aggregators)
# REQUEST_ID_HEADER=X-Request-ID       # Correlation id header

# === Optional ===
# FREE_TRIES_PER_DAY=0
# CAPTION_FONT_PATH=
# CAPTION_MAX_CHARS=120
# CAPTION_PADDING_SECONDS=0.15
# CLEANUP_TEMP_MAX_DAYS=0
# CLEANUP_OUTPUTS_MAX_DAYS=7
